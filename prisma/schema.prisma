// ─────────────────────────────────────────────────────────────
// Temple AI OS — Prisma Schema
// Provider: PostgreSQL (Supabase)
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  SUPER_ADMIN
  TEMPLE_ADMIN
  STAFF
  DEVOTEE

  @@map("user_role")
}

enum TempleMemberRole {
  TEMPLE_ADMIN
  STAFF

  @@map("temple_member_role")
}

enum TempleType {
  SHIVA
  VISHNU
  SHAKTI
  GANESH
  HANUMAN
  MURUGAN
  AYYAPPA
  JAIN
  SIKH
  BUDDHIST
  OTHER

  @@map("temple_type")
}

enum SubscriptionPlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE

  @@map("subscription_plan_type")
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  CASH
  CHEQUE
  BANK_TRANSFER
  RAZORPAY
  OTHER

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED

  @@map("payment_status")
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY

  @@map("recurrence_interval")
}

enum EventType {
  FESTIVAL
  POOJA
  SATSANG
  PRAVACHAN
  CULTURAL
  CHARITABLE
  WORKSHOP
  YATRA
  OTHER

  @@map("event_type")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED

  @@map("event_status")
}

enum RegistrationStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
  ATTENDED

  @@map("registration_status")
}

enum VolunteerStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("volunteer_status")
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("assignment_status")
}

enum PageType {
  HOME
  ABOUT
  HISTORY
  DARSHAN
  SEVAS
  DONATIONS
  EVENTS
  GALLERY
  CONTACT
  CUSTOM

  @@map("page_type")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT

  @@map("media_type")
}

enum AnnouncementType {
  GENERAL
  URGENT
  FESTIVAL
  MAINTENANCE
  CLOSURE
  SPECIAL_DARSHAN

  @@map("announcement_type")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING

  @@map("subscription_status")
}

enum SevaBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW

  @@map("seva_booking_status")
}

// ═══════════════════════════════════════════════════════════════
// 1. USERS — extends Supabase auth.users
// ═══════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(uuid()) @db.Uuid
  fullName  String?  @map("full_name")
  phone     String?
  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(DEVOTEE)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  templeMembers TempleMember[]
  devotees      Devotee[]
  donations     Donation[]     @relation("DonationCreator")
  expenses      Expense[]      @relation("ExpenseCreator")
  auditLogs     AuditLog[]

  @@map("users")
}

// ═══════════════════════════════════════════════════════════════
// 2. TEMPLES
// ═══════════════════════════════════════════════════════════════

model Temple {
  id                  String             @id @default(uuid()) @db.Uuid
  slug                String             @unique
  name                String
  templeType          TempleType?        @map("temple_type")
  primaryDeity        String?            @map("primary_deity")
  history             Json?
  address             Json?
  timings             Json?
  contactPhone        String?            @map("contact_phone")
  contactEmail        String?            @map("contact_email")
  websiteDomain       String?            @map("website_domain")
  upiId               String?            @map("upi_id")
  bankDetails         Json?              @map("bank_details")
  trustRegistrationNo String?            @map("trust_registration_no")
  trust80gDetails     Json?              @map("trust_80g_details")
  trust12aDetails     Json?              @map("trust_12a_details")
  socialLinks         Json?              @map("social_links")
  peethadhipati       Json?
  trustees            Json?
  servicesOffered     String[]           @map("services_offered")
  logoUrl             String?            @map("logo_url")
  coverImageUrl       String?            @map("cover_image_url")
  themeConfig         Json?              @map("theme_config")
  seoConfig           Json?              @map("seo_config")
  liveStreamUrl       String?            @map("live_stream_url")
  isPublished         Boolean            @default(false) @map("is_published")
  isActive            Boolean            @default(true) @map("is_active")
  subscriptionPlan    SubscriptionPlanType @default(FREE) @map("subscription_plan")
  onboardingCompleted Boolean            @default(false) @map("onboarding_completed")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  members            TempleMember[]
  devotees           Devotee[]
  donationCategories DonationCategory[]
  donations          Donation[]
  receipts           Receipt[]
  events             Event[]
  eventRegistrations EventRegistration[]
  volunteers         Volunteer[]
  volunteerAssignments VolunteerAssignment[]
  poojaTypes         PoojaType[]
  pages              TemplePage[]
  media              Media[]
  announcements      Announcement[]
  subscriptions      Subscription[]
  aiGenerations      AiGeneration[]
  sevas              Seva[]
  sevaBookings       SevaBooking[]
  expenses           Expense[]
  auditLogs          AuditLog[]
  campaigns          Campaign[]
  spiritualHabits    SpiritualHabit[]
  inventoryItems     InventoryItem[]
  communitySuggestions CommunitySuggestion[]
  roadmapItems       RoadmapItem[]

  @@index([slug])
  @@index([isPublished, isActive])
  @@map("temples")
}

// ═══════════════════════════════════════════════════════════════
// 3. TEMPLE MEMBERS — staff & admin assignments
// ═══════════════════════════════════════════════════════════════

model TempleMember {
  id          String           @id @default(uuid()) @db.Uuid
  templeId    String           @map("temple_id") @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  role        TempleMemberRole @default(STAFF)
  permissions Json?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([templeId, userId])
  @@index([templeId])
  @@index([userId])
  @@map("temple_members")
}

// ═══════════════════════════════════════════════════════════════
// 4. DEVOTEES
// ═══════════════════════════════════════════════════════════════

model Devotee {
  id           String    @id @default(uuid()) @db.Uuid
  templeId     String    @map("temple_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  fullName     String    @map("full_name")
  phone        String?
  email        String?
  address      Json?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  anniversary  DateTime? @db.Date
  gotra        String?
  nakshatra    String?
  tags         String[]
  notes        String?
  totalDonated Decimal   @default(0) @map("total_donated") @db.Decimal(12, 2)
  visitCount   Int       @default(0) @map("visit_count")
  lastVisitAt  DateTime? @map("last_visit_at") @db.Timestamptz
  karmaPoints  Int       @default(0) @map("karma_points")
  badgeTier    String    @default("BRONZE") @map("badge_tier")
  badges       String[]  @default([])
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  temple             Temple              @relation(fields: [templeId], references: [id], onDelete: Cascade)
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  donations          Donation[]
  eventRegistrations EventRegistration[]
  volunteers         Volunteer[]
  sevaBookings       SevaBooking[]
  spiritualHabits    SpiritualHabit[]
  communitySuggestions CommunitySuggestion[]

  @@index([templeId])
  @@index([userId])
  @@index([templeId, phone])
  @@index([templeId, email])
  @@map("devotees")
}

// ═══════════════════════════════════════════════════════════════
// 5. DONATION CATEGORIES
// ═══════════════════════════════════════════════════════════════

model DonationCategory {
  id               String   @id @default(uuid()) @db.Uuid
  templeId         String   @map("temple_id") @db.Uuid
  name             String
  description      String?
  suggestedAmounts Int[]    @map("suggested_amounts")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")

  // Relations
  temple    Temple     @relation(fields: [templeId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([templeId])
  @@map("donation_categories")
}

// ═══════════════════════════════════════════════════════════════
// 6. DONATIONS
// ═══════════════════════════════════════════════════════════════

model Donation {
  id                 String              @id @default(uuid()) @db.Uuid
  templeId           String              @map("temple_id") @db.Uuid
  devoteeId          String?             @map("devotee_id") @db.Uuid
  categoryId         String              @map("category_id") @db.Uuid
  campaignId         String?             @map("campaign_id") @db.Uuid
  amount             Decimal             @db.Decimal(12, 2)
  currency           String              @default("INR")
  paymentMethod      PaymentMethod       @map("payment_method")
  paymentStatus      PaymentStatus       @default(PENDING) @map("payment_status")
  razorpayOrderId    String?             @map("razorpay_order_id")
  razorpayPaymentId  String?             @map("razorpay_payment_id")
  transactionRef     String?             @map("transaction_ref")
  isAnonymous        Boolean             @default(false) @map("is_anonymous")
  isRecurring        Boolean             @default(false) @map("is_recurring")
  recurrenceInterval RecurrenceInterval? @map("recurrence_interval")
  donorName          String?             @map("donor_name")
  donorPhone         String?             @map("donor_phone")
  donorPan           String?             @map("donor_pan")
  notes              String?
  blockchainHash     String?             @unique @map("blockchain_hash")
  eventId            String?             @map("event_id") @db.Uuid
  createdBy          String              @map("created_by") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple   Temple            @relation(fields: [templeId], references: [id], onDelete: Cascade)
  devotee  Devotee?          @relation(fields: [devoteeId], references: [id], onDelete: SetNull)
  category DonationCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  event    Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  campaign Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  creator  User              @relation("DonationCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  receipts Receipt[]

  @@index([templeId])
  @@index([devoteeId])
  @@index([templeId, paymentStatus])
  @@index([templeId, createdAt])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@map("donations")
}

// ═══════════════════════════════════════════════════════════════
// 7. RECEIPTS
// ═══════════════════════════════════════════════════════════════

model Receipt {
  id            String    @id @default(uuid()) @db.Uuid
  templeId      String    @map("temple_id") @db.Uuid
  donationId    String    @map("donation_id") @db.Uuid
  receiptNumber String    @unique @map("receipt_number")
  pdfUrl        String?   @map("pdf_url")
  sentEmail     Boolean   @default(false) @map("sent_email")
  sentWhatsapp  Boolean   @default(false) @map("sent_whatsapp")
  sentAt        DateTime? @map("sent_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple   Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([donationId])
  @@map("receipts")
}

// ═══════════════════════════════════════════════════════════════
// 8. EVENTS
// ═══════════════════════════════════════════════════════════════

model Event {
  id                 String      @id @default(uuid()) @db.Uuid
  templeId           String      @map("temple_id") @db.Uuid
  title              Json
  description        Json?
  eventType          EventType   @map("event_type")
  startDate          DateTime    @map("start_date") @db.Timestamptz
  endDate            DateTime    @map("end_date") @db.Timestamptz
  location           String?
  maxRegistrations   Int?        @map("max_registrations")
  registrationCount  Int         @default(0) @map("registration_count")
  isRegistrationOpen Boolean     @default(true) @map("is_registration_open")
  isFree             Boolean     @default(true) @map("is_free")
  ticketPrice        Decimal?    @map("ticket_price") @db.Decimal(10, 2)
  posterUrl          String?     @map("poster_url")
  status             EventStatus @default(DRAFT)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  temple               Temple                @relation(fields: [templeId], references: [id], onDelete: Cascade)
  registrations        EventRegistration[]
  donations            Donation[]
  volunteerAssignments VolunteerAssignment[]

  @@index([templeId])
  @@index([templeId, status])
  @@index([templeId, startDate])
  @@map("events")
}

// ═══════════════════════════════════════════════════════════════
// 9. EVENT REGISTRATIONS
// ═══════════════════════════════════════════════════════════════

model EventRegistration {
  id               String             @id @default(uuid()) @db.Uuid
  eventId          String             @map("event_id") @db.Uuid
  devoteeId        String             @map("devotee_id") @db.Uuid
  templeId         String             @map("temple_id") @db.Uuid
  status           RegistrationStatus @default(REGISTERED)
  registrationDate DateTime           @default(now()) @map("registration_date") @db.Timestamptz
  attendedAt       DateTime?          @map("attended_at") @db.Timestamptz

  // Relations
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  devotee Devotee @relation(fields: [devoteeId], references: [id], onDelete: Cascade)
  temple  Temple  @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@unique([eventId, devoteeId])
  @@index([templeId])
  @@index([eventId])
  @@index([devoteeId])
  @@map("event_registrations")
}

// ═══════════════════════════════════════════════════════════════
// 10. VOLUNTEERS
// ═══════════════════════════════════════════════════════════════

model Volunteer {
  id           String          @id @default(uuid()) @db.Uuid
  templeId     String          @map("temple_id") @db.Uuid
  devoteeId    String          @map("devotee_id") @db.Uuid
  status       VolunteerStatus @default(PENDING)
  skills       String[]
  availability Json?
  totalHours   Decimal         @default(0) @map("total_hours") @db.Decimal(8, 2)
  certificates Json?
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple      Temple                @relation(fields: [templeId], references: [id], onDelete: Cascade)
  devotee     Devotee               @relation(fields: [devoteeId], references: [id], onDelete: Cascade)
  assignments VolunteerAssignment[]

  @@unique([templeId, devoteeId])
  @@index([templeId])
  @@index([devoteeId])
  @@map("volunteers")
}

// ═══════════════════════════════════════════════════════════════
// 11. VOLUNTEER ASSIGNMENTS
// ═══════════════════════════════════════════════════════════════

model VolunteerAssignment {
  id          String           @id @default(uuid()) @db.Uuid
  volunteerId String           @map("volunteer_id") @db.Uuid
  eventId     String           @map("event_id") @db.Uuid
  templeId    String           @map("temple_id") @db.Uuid
  task        String?
  status      AssignmentStatus @default(ASSIGNED)
  hoursLogged Decimal          @default(0) @map("hours_logged") @db.Decimal(6, 2)

  // Relations
  volunteer Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  temple    Temple    @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([volunteerId])
  @@index([eventId])
  @@map("volunteer_assignments")
}

// ═══════════════════════════════════════════════════════════════
// 12. POOJA TYPES
// ═══════════════════════════════════════════════════════════════

model PoojaType {
  id              String  @id @default(uuid()) @db.Uuid
  templeId        String  @map("temple_id") @db.Uuid
  name            Json
  description     Json?
  price           Decimal @db.Decimal(10, 2)
  durationMinutes Int     @map("duration_minutes")
  isActive        Boolean @default(true) @map("is_active")

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@map("pooja_types")
}

// ═══════════════════════════════════════════════════════════════
// 13. TEMPLE PAGES — CMS pages per temple
// ═══════════════════════════════════════════════════════════════

model TemplePage {
  id          String   @id @default(uuid()) @db.Uuid
  templeId    String   @map("temple_id") @db.Uuid
  pageType    PageType @map("page_type")
  content     Json?
  seoMeta     Json?    @map("seo_meta")
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@unique([templeId, pageType])
  @@index([templeId])
  @@map("temple_pages")
}

// ═══════════════════════════════════════════════════════════════
// 14. MEDIA — images, videos, documents
// ═══════════════════════════════════════════════════════════════

model Media {
  id           String    @id @default(uuid()) @db.Uuid
  templeId     String    @map("temple_id") @db.Uuid
  type         MediaType
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  title        String?
  category     String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([templeId, type])
  @@map("media")
}

// ═══════════════════════════════════════════════════════════════
// 15. ANNOUNCEMENTS
// ═══════════════════════════════════════════════════════════════

model Announcement {
  id          String           @id @default(uuid()) @db.Uuid
  templeId    String           @map("temple_id") @db.Uuid
  title       Json
  content     Json?
  type        AnnouncementType @default(GENERAL)
  isPinned    Boolean          @default(false) @map("is_pinned")
  publishedAt DateTime         @default(now()) @map("published_at") @db.Timestamptz
  expiresAt   DateTime?        @map("expires_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([templeId, isPinned])
  @@index([templeId, publishedAt])
  @@map("announcements")
}

// ═══════════════════════════════════════════════════════════════
// 16. SUBSCRIPTION PLANS — platform-level billing tiers
// ═══════════════════════════════════════════════════════════════

model SubscriptionPlan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  displayName  String   @map("display_name")
  priceMonthly Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal  @map("price_yearly") @db.Decimal(10, 2)
  features     Json?
  limits       Json?
  isActive     Boolean  @default(true) @map("is_active")

  // Relations
  subscriptions Subscription[]

  @@map("subscription_plans")
}

// ═══════════════════════════════════════════════════════════════
// 17. SUBSCRIPTIONS — temple ↔ plan binding
// ═══════════════════════════════════════════════════════════════

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  templeId               String             @map("temple_id") @db.Uuid
  planId                 String             @map("plan_id") @db.Uuid
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime           @map("current_period_start") @db.Timestamptz
  currentPeriodEnd       DateTime           @map("current_period_end") @db.Timestamptz
  razorpaySubscriptionId String?            @map("razorpay_subscription_id")
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple Temple           @relation(fields: [templeId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([templeId])
  @@index([templeId, status])
  @@map("subscriptions")
}

// ═══════════════════════════════════════════════════════════════
// 18. AI GENERATIONS — Gemini API usage log
// ═══════════════════════════════════════════════════════════════

model AiGeneration {
  id         String   @id @default(uuid()) @db.Uuid
  templeId   String   @map("temple_id") @db.Uuid
  type       String
  prompt     String
  result     Json?
  modelUsed  String?  @map("model_used")
  tokensUsed Int?     @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([templeId, type])
  @@map("ai_generations")
}

// ═══════════════════════════════════════════════════════════════
// 19. SEVAS — temple service offerings
// ═══════════════════════════════════════════════════════════════

model Seva {
  id              String   @id @default(uuid()) @db.Uuid
  templeId        String   @map("temple_id") @db.Uuid
  name            Json
  description     Json?
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @map("duration_minutes")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple   Temple        @relation(fields: [templeId], references: [id], onDelete: Cascade)
  bookings SevaBooking[]

  @@index([templeId])
  @@map("sevas")
}

// ═══════════════════════════════════════════════════════════════
// 20. SEVA BOOKINGS
// ═══════════════════════════════════════════════════════════════

model SevaBooking {
  id                String            @id @default(uuid()) @db.Uuid
  templeId          String            @map("temple_id") @db.Uuid
  sevaId            String            @map("seva_id") @db.Uuid
  devoteeId         String            @map("devotee_id") @db.Uuid
  bookingDate       DateTime          @map("booking_date") @db.Date
  bookingTime       String            @map("booking_time")
  status            SevaBookingStatus @default(PENDING)
  paymentStatus     PaymentStatus     @default(PENDING) @map("payment_status")
  razorpayPaymentId String?           @map("razorpay_payment_id")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple  Temple  @relation(fields: [templeId], references: [id], onDelete: Cascade)
  seva    Seva    @relation(fields: [sevaId], references: [id], onDelete: Cascade)
  devotee Devotee @relation(fields: [devoteeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([sevaId])
  @@index([devoteeId])
  @@index([templeId, bookingDate])
  @@map("seva_bookings")
}

// ═══════════════════════════════════════════════════════════════
// 21. AUDIT LOGS — immutable action log
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  templeId   String   @map("temple_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([userId])
  @@index([templeId, entityType])
  @@index([templeId, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════
// 22. ROLE PERMISSIONS — RBAC lookup table
// ═══════════════════════════════════════════════════════════════

model RolePermission {
  id         String @id @default(uuid()) @db.Uuid
  role       String
  permission String

  @@unique([role, permission])
  @@index([role])
  @@map("role_permissions")
}

// ═══════════════════════════════════════════════════════════════
// 23. EXPENSES
// ═══════════════════════════════════════════════════════════════

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  templeId    String   @map("temple_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  date        DateTime @db.Date
  notes       String?
  receiptUrl  String?  @map("receipt_url")
  isAnomaly   Boolean  @default(false) @map("is_anomaly")
  anomalyReason String? @map("anomaly_reason")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple  Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)
  creator User   @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([templeId])
  @@index([templeId, date])
  @@map("expenses")
}

// ═══════════════════════════════════════════════════════════════
// 24. CAMPAIGNS — Live Crowdfunding
// ═══════════════════════════════════════════════════════════════

model Campaign {
  id            String    @id @default(uuid()) @db.Uuid
  templeId      String    @map("temple_id") @db.Uuid
  title         String
  description   String?
  targetAmount  Decimal   @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(12, 2)
  isActive      Boolean   @default(true) @map("is_active")
  endDate       DateTime? @map("end_date") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)
  roadmapItems RoadmapItem[]
  donations    Donation[]

  @@index([templeId])
  @@index([templeId, isActive])
  @@map("campaigns")
}

// ═══════════════════════════════════════════════════════════════
// 25. SPIRITUAL HABITS (Continuum)
// ═══════════════════════════════════════════════════════════════

model SpiritualHabit {
  id              String   @id @default(uuid()) @db.Uuid
  templeId        String   @map("temple_id") @db.Uuid
  devoteeId       String   @map("devotee_id") @db.Uuid
  habitName       String   @map("habit_name")
  streakCount     Int      @default(0) @map("streak_count")
  lastCompletedAt DateTime? @map("last_completed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple  Temple  @relation(fields: [templeId], references: [id], onDelete: Cascade)
  devotee Devotee @relation(fields: [devoteeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([devoteeId])
  @@map("spiritual_habits")
}

// ═══════════════════════════════════════════════════════════════
// 26. INVENTORY ITEMS (Stackwise)
// ═══════════════════════════════════════════════════════════════

enum InventoryCategory {
  PRASAD
  EVENT
  MAINTENANCE
  OTHER

  @@map("inventory_category")
}

model InventoryItem {
  id            String            @id @default(uuid()) @db.Uuid
  templeId      String            @map("temple_id") @db.Uuid
  itemName      String            @map("item_name")
  category      InventoryCategory @default(OTHER)
  currentStock  Decimal           @default(0) @map("current_stock") @db.Decimal(10, 2)
  unit          String
  reorderLevel  Decimal           @default(0) @map("reorder_level") @db.Decimal(10, 2)
  lastRestocked DateTime?         @map("last_restocked") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@map("inventory_items")
}

// ═══════════════════════════════════════════════════════════════
// 27. COMMUNITY SUGGESTIONS (Upvote)
// ═══════════════════════════════════════════════════════════════

model CommunitySuggestion {
  id          String   @id @default(uuid()) @db.Uuid
  templeId    String   @map("temple_id") @db.Uuid
  devoteeId   String   @map("devotee_id") @db.Uuid
  title       String
  description String?
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple  Temple  @relation(fields: [templeId], references: [id], onDelete: Cascade)
  devotee Devotee @relation(fields: [devoteeId], references: [id], onDelete: Cascade)

  @@index([templeId])
  @@index([devoteeId])
  @@map("community_suggestions")
}

// ═══════════════════════════════════════════════════════════════
// 28. ROADMAP ITEMS (Roadmapper)
// ═══════════════════════════════════════════════════════════════

enum RoadmapStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED

  @@map("roadmap_status")
}

model RoadmapItem {
  id          String        @id @default(uuid()) @db.Uuid
  templeId    String        @map("temple_id") @db.Uuid
  campaignId  String?       @map("campaign_id") @db.Uuid
  title       String
  description String?
  status      RoadmapStatus @default(PLANNED)
  targetDate  DateTime?     @map("target_date") @db.Date
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  temple   Temple    @relation(fields: [templeId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([templeId])
  @@index([campaignId])
  @@map("roadmap_items")
}
